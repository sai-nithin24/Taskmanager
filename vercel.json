{
  "version": 2,
  "name": "taskboard",
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/css/(.*)",
      "dest": "/public/assets/css/$1"
    },
    {
      "src": "/assets/js/(.*)",
      "dest": "/public/assets/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
